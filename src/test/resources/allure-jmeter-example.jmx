            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"/>
            <stringProp name="parameters"/>
            <stringProp name="script">vars.getObject("allure.clearLabels")?.call()
log.warn(vars.getObject("allure.clearLabels"))
vars.put("allure.name","Bug T1");
vars.put("allure.label.epic","Epic1");
vars.put("allure.label.feature","Feature1");
vars.put("allure.label.story","Story1");</stringProp>
